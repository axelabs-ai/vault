From ab6853247568c91260eae4110d2204403ec79bfe Mon Sep 17 00:00:00 2001
From: DK <team@realchoice.co.kr>
Date: Tue, 26 May 2026 08:43:28 +0900
Subject: [PATCH 2/2] axe: backport AccountKeys + MasterPasswordUnlock to token
 response

Bitwarden client >= 2026.4 reads new wrapped-variant fields from the
token response: AccountKeys.publicKeyEncryptionKeyPair.wrappedPrivateKey
and UserDecryptionOptions.MasterPasswordUnlock with MasterKeyWrappedUserKey.
Missing fields cause the client to throw 'Cannot read properties of null
(reading toWrappedAccountCryptographicState)' during unlock.

Backported from dani-garcia/vaultwarden mainline src/api/identity.rs
which already exposes these fields.
---
 src/api/identity.rs | 39 ++++++++++++++++++++++++++++++++++++++-
 1 file changed, 38 insertions(+), 1 deletion(-)

diff --git a/src/api/identity.rs b/src/api/identity.rs
index 8d7a43cf..c1f5be86 100644
--- a/src/api/identity.rs
+++ b/src/api/identity.rs
@@ -487,6 +487,41 @@ async fn authenticated_response(
 
     let mp_policy = master_password_policy(user, conn).await;
 
+    // AXE patch — Bitwarden client >= 2026.4 expects new "wrapped" variants
+    // (MasterKeyWrappedUserKey, wrappedPrivateKey, AccountKeys) in the token
+    // response. Backported from dani-garcia/vaultwarden mainline. Without
+    // these, the client throws "Cannot read properties of null (reading
+    // 'toWrappedAccountCryptographicState')" during unlock.
+    let has_master_password = !user.password_hash.is_empty();
+    let master_password_unlock = if has_master_password {
+        json!({
+            "Kdf": {
+                "KdfType": user.client_kdf_type,
+                "Iterations": user.client_kdf_iter,
+                "Memory": user.client_kdf_memory,
+                "Parallelism": user.client_kdf_parallelism
+            },
+            "MasterKeyEncryptedUserKey": user.akey,
+            "MasterKeyWrappedUserKey": user.akey,
+            "Salt": user.email
+        })
+    } else {
+        Value::Null
+    };
+
+    let account_keys = if user.private_key.is_some() {
+        json!({
+            "publicKeyEncryptionKeyPair": {
+                "wrappedPrivateKey": user.private_key,
+                "publicKey": user.public_key,
+                "Object": "publicKeyEncryptionKeyPair"
+            },
+            "Object": "privateKeys"
+        })
+    } else {
+        Value::Null
+    };
+
     let mut result = json!({
         "access_token": auth_tokens.access_token(),
         "expires_in": auth_tokens.expires_in(),
@@ -501,8 +536,10 @@ async fn authenticated_response(
         "ForcePasswordReset": false,
         "MasterPasswordPolicy": mp_policy,
         "scope": auth_tokens.scope(),
+        "AccountKeys": account_keys,
         "UserDecryptionOptions": {
-            "HasMasterPassword": !user.password_hash.is_empty(),
+            "HasMasterPassword": has_master_password,
+            "MasterPasswordUnlock": master_password_unlock,
             "Object": "userDecryptionOptions"
         },
     });
