From 30835e9b57d58dfb92bd2e349b86b4b2de0e0d33 Mon Sep 17 00:00:00 2001
From: DK <team@realchoice.co.kr>
Date: Tue, 26 May 2026 01:20:14 +0900
Subject: [PATCH 1/2] axe: alias /accounts/prelogin/password to
 /accounts/prelogin

Bitwarden client >= 2026.4 (Chrome extension 2026.4.1, observed)
calls the dedicated /accounts/prelogin/password endpoint for the
password-grant prelogin flow. Upstream Timshel only exposes the
legacy /accounts/prelogin route, so clients receive 404 and fail
the unlock flow before submitting credentials.

Adds the alias in both src/api/identity.rs and src/api/core/accounts.rs
so requests are routed identically regardless of /identity/ vs /api/
mount prefix. Handler delegates to the existing _prelogin function
since the KDF payload contract is unchanged.
---
 src/api/core/accounts.rs | 9 +++++++++
 src/api/identity.rs      | 9 +++++++++
 2 files changed, 18 insertions(+)

diff --git a/src/api/core/accounts.rs b/src/api/core/accounts.rs
index ed374f5f..0214474e 100644
--- a/src/api/core/accounts.rs
+++ b/src/api/core/accounts.rs
@@ -49,6 +49,7 @@ pub fn routes() -> Vec<rocket::Route> {
         revision_date,
         password_hint,
         prelogin,
+        prelogin_password,
         verify_password,
         api_key,
         rotate_api_key,
@@ -1128,6 +1129,14 @@ async fn prelogin(data: Json<PreloginData>, conn: DbConn) -> Json<Value> {
     _prelogin(data, conn).await
 }
 
+// AXE patch — Bitwarden client >= 2026.4 calls `/accounts/prelogin/password`
+// as the dedicated password-flow prelogin endpoint. Alias to the same handler
+// since Vaultwarden's KDF payload is identical for the password grant path.
+#[post("/accounts/prelogin/password", data = "<data>")]
+async fn prelogin_password(data: Json<PreloginData>, conn: DbConn) -> Json<Value> {
+    _prelogin(data, conn).await
+}
+
 pub async fn _prelogin(data: Json<PreloginData>, mut conn: DbConn) -> Json<Value> {
     let data: PreloginData = data.into_inner();
 
diff --git a/src/api/identity.rs b/src/api/identity.rs
index 1d31386f..8d7a43cf 100644
--- a/src/api/identity.rs
+++ b/src/api/identity.rs
@@ -34,6 +34,7 @@ pub fn routes() -> Vec<Route> {
     routes![
         login,
         prelogin,
+        prelogin_password,
         identity_register,
         register_verification_email,
         register_finish,
@@ -882,6 +883,14 @@ async fn prelogin(data: Json<PreloginData>, conn: DbConn) -> Json<Value> {
     _prelogin(data, conn).await
 }
 
+// AXE patch — Bitwarden client >= 2026.4 calls `/accounts/prelogin/password`
+// as the dedicated password-flow prelogin endpoint. Alias to the same handler
+// since Vaultwarden's KDF payload is identical for the password grant path.
+#[post("/accounts/prelogin/password", data = "<data>")]
+async fn prelogin_password(data: Json<PreloginData>, conn: DbConn) -> Json<Value> {
+    _prelogin(data, conn).await
+}
+
 #[post("/accounts/register", data = "<data>")]
 async fn identity_register(data: Json<RegisterData>, conn: DbConn) -> JsonResult {
     _register(data, false, conn).await
