# Vaultwarden data — NEVER commit
data/
caddy-data/

# Local secrets fallback (real secrets live in ~/.config/vault/.env)
env.local
.env
.env.*

# Backups — content goes to ~/backups/vault/, never under repo
backups/

# GPG keys
*.gpg
*.asc
*.key

# Allowlist: vault-backup public key is safe to commit (Dockerfile needs it
# at build time and it's the *public* half by design)
!vault-backup.pub.asc
!cron/keys/vault-backup.pub.asc

# macOS noise
.DS_Store

# Editor noise
.vscode/
.idea/
*.swp
